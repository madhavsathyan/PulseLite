# PulseLite Environment Configuration Example
# Copy this file to '.env' and fill in your details to connect to the Reddit API.
# If left empty or unset, the system will fall back to simulated social media streams.

# Kafka Configuration (defaults are configured in docker-compose.yml)
KAFKA_BROKER=kafka:29092
KAFKA_TOPIC=social_media_posts

# PostgreSQL Sink Configuration
POSTGRES_HOST=postgres
POSTGRES_DB=pulselite
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Reddit Public API Ingestion Configuration
# Set these to fetch real-time posts/comments from Reddit.
# Register an application at https://www.reddit.com/prefs/apps/ (select 'script')
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=python:pulselite:v1.0 (by /u/YOUR_REDDIT_USERNAME)

# Comma-separated list of subreddits to ingest (no spaces)
REDDIT_SUBREDDITS=india,cricket,technology,gaming,movies,news

# Stream type: 'comments' (high volume) or 'submissions' (lower volume)
REDDIT_STREAM_TYPE=comments
